{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/customer/(.*)",
      "destination": "/frontend/customer/$1"
    },
    {
      "source": "/customer",
      "destination": "/frontend/customer/index.html"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/frontend/admin/$1"
    },
    {
      "source": "/admin",
      "destination": "/frontend/admin/index.html"
    },
    {
      "source": "/",
      "destination": "/frontend/customer/index.html"
    }
  ]
}
