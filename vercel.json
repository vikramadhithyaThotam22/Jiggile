{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/customer/(.*)", "dest": "/frontend/customer/$1" },
    { "src": "/admin/(.*)", "dest": "/frontend/admin/$1" },
    { "src": "/customer$", "dest": "/frontend/customer/index.html" },
    { "src": "/admin$", "dest": "/frontend/admin/index.html" },
    { "src": "^/$", "dest": "/frontend/customer/index.html" }
  ]
}
